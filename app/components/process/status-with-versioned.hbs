{{#if (and @isShown this.isListDiverging)}}
  {{#unless (eq this.countOfCurrent 0)}}
    <AuPill @skin="success" class="au-u-margin-left-small">
      {{this.postfixAdded}}
      toegevoegd
    </AuPill>
  {{/unless}}
  {{#unless (eq this.countOfVersioned 0)}}
    <AuPill @skin="error" class="au-u-margin-left-small">
      {{this.postfixRemoved}}
      verwijderd
    </AuPill>
  {{/unless}}
{{/if}}