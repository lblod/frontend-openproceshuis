{{#if @isShown}}
  {{#unless (eq this.countOfCurrent 0)}}
    <AuPill @skin="success">
      {{this.postfixAdded}}
      toegevoegd
    </AuPill>
  {{/unless}}
  {{#unless (eq this.countOfVersioned 0)}}
    <AuPill @skin="error">
      {{this.postfixRemoved}}
      verwijderd
    </AuPill>
  {{/unless}}
{{/if}}