<div class={{if @error "ember-power-select--error"}} ...attributes>
  <PowerSelect
    @searchEnabled={{true}}
    @searchField="created"
    @loadingMessage="Aan het laden..."
    @noMatchesMessage="Geen resultaten"
    @options={{this.versions}}
    @selected={{this.selected}}
    @onChange={{this.onVersionChanged}}
    @onOpen={{perform this.fetchProcessVersions}}
    @triggerId={{@id}}
    as |process|
  >
    {{#if process.isFirst}}
      Huidige versie
    {{else}}
      {{or (date-format process.created true) process.id}}
    {{/if}}
  </PowerSelect>
</div>