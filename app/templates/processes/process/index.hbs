{{page-title this.model.process.title}}
{{breadcrumb
  this.model.process.title
  route=this.model.breadcrumRouteName
  models=this.model.process.id
}}

{{#if this.isEditingDetails}}
  <PageHeader>
    <:title>
      Wijzig proces
    </:title>
    <:action>
      <AuPill @icon="clock-rewind" @draft="true">Laatst aangepast op
        {{date-format this.process.modified true}}</AuPill>
    </:action>
  </PageHeader>
{{else}}
  <PageHeader>
    <:title>
      <div class="au-u-flex au-u-flex--vertical-center">
        {{this.process.title}}
        <AuButton
          class="au-u-padding-left-small"
          @icon="link"
          @skin="link"
          @hideText={{true}}
          {{on "click" this.copyUrl}}
        /></div>
    </:title>
    <:action>
      <div class="au-u-flex au-u-flex--column au-o-flow">
        <AuPill @icon="clock-rewind">Laatst aangepast op
          {{date-format this.process.modified true}}</AuPill>
        <Process::VersionSelector
          @process={{@model.process}}
          @selectedId={{this.processVersion}}
          @onSelected={{this.onProcessVersionSelected}}
        />
      </div>
    </:action>
  </PageHeader>
{{/if}}

<AuBodyContainer class="au-o-box au-o-flow" @scroll={{true}}>

  <Process::DetailsCard
    @canEdit={{this.canEdit}}
    @process={{this.process}}
    @versionedProcessId={{this.processVersion}}
    @setIsEditing={{this.setIsEditingDetails}}
  />

  <Process::InventoryProcessCard
    @canEdit={{this.canEdit}}
    @process={{this.process}}
  />

  <span>
    <div class="au-u-flex au-u-flex--between au-u-margin-bottom-small">
      <AuHeading @level="2" @skin="3">Diagrammen</AuHeading>
      <AuButtonGroup>
        <File::DownloadMultipleAsZip
          @buttonLabel="Download alle"
          @folderName={{this.diagramsDownloadFolderName}}
          @files={{this.diagramFiles}}
          @onDownloadSuccesful={{this.onDiagramsDownloadedAsZip}}
        />
        {{#if this.isPublisherOfProcess}}
          <AuButton
            @skin="naked"
            {{on "click" (fn (mut this.isWizardModalOpen) true)}}
          >
            Wijzig
          </AuButton>
        {{/if}}

      </AuButtonGroup>
    </div>
    {{#if (and @model.diagramList @model.diagramList.version)}}
      <p
        class="au-u-muted au-u-h6 au-u-text-right"
      >{{@model.diagramList.version}}</p>
    {{/if}}
    {{#if @model.diagramList}}
      <div>
        <DiagramList::Table
          @diagramList={{@model.diagramList}}
          @selectedDiagramFile={{this.selectedDiagramFile}}
          @onDiagramFileSelected={{this.openDiagramFile}}
          @process={{@model.process}}
          @page={{this.diagramsPage}}
          @sort={{this.diagramsSort}}
        />
      </div>
      <div class="au-o-box au-u-background-gray-100">
        <File::Viewer @file={{this.selectedDiagramFile}} />
      </div>
    {{else}}
      <div
        class="au-u-flex au-u-flex--center au-u-flex--column au-u-text-center au-u-margin-bottom"
      >
        <p class="au-u-h3 au-u-muted">Er werden geen diagrammen gevonden</p>
        {{#if this.isPublisherOfProcess}}
          <p class="au-u-muted">Klik de wijzig en maak een nieuwe versie aan</p>
        {{/if}}
      </div>
    {{/if}}
  </span>

  {{#if (and this.process.isBlueprint this.process.isPublishedByAbbOrDv)}}
    <Process::IcrCard @canEdit={{this.canEdit}} @process={{this.process}} />
  {{else}}
    <Process::BlueprintCard
      @canEdit={{this.canEdit}}
      @process={{this.process}}
    />
  {{/if}}

  <Process::Diagram::Version
    @canEdit={{this.canEdit}}
    @process={{this.process}}
    @page={{this.diagramVersionsPage}}
    @sort={{this.diagramVersionsSort}}
    @trackDownloadFileEvent={{this.trackDownloadFileEvent}}
    @reloadTableData={{this.fetchDiagramVersions}}
  />

  <Process::Attachments
    @canEdit={{this.canEdit}}
    @process={{this.process}}
    @trackDownloadFileEvent={{this.trackDownloadFileEvent}}
    @page={{this.attachmentsPage}}
    @size={{this.attachmentsSize}}
    @sort={{this.attachmentsSort}}
    @reloadTableData={{this.fetchAttachments}}
  />

  <Process::Usage
    @process={{this.process}}
    @refreshDataTrigger={{this.isEditingDetails}}
  />

  {{#if this.isWizardModalOpen}}
    <Process::Wizard
      @onCloseModal={{fn (mut this.isWizardModalOpen) false}}
      @process={{@model.process}}
    />
  {{/if}}

</AuBodyContainer>